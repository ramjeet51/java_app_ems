# ---------------------------------------------------------
# Frontend environment configuration
# Copy this file to .env.local and fill in real values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser bundle —
# never put secrets there. Server-only values have no prefix.
# ---------------------------------------------------------

# Server-side only: where Next.js forwards /backend/* API calls (see next.config.js)
BACKEND_INTERNAL_URL=http://localhost:8080

# Public base path the browser uses to call the API (proxied through Next.js)
NEXT_PUBLIC_API_BASE_URL=/backend

# Unsplash API (https://unsplash.com/developers) - used for employee/department imagery
# This is a public "Access Key" intended for client-side demo use with rate limits;
# for production, proxy Unsplash calls through your own backend instead.
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
