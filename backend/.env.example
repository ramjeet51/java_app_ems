# ---------------------------------------------------------
# Backend environment configuration
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.
# ---------------------------------------------------------

# Server
SERVER_PORT=8080

# Database (MySQL)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ems_db
DB_USERNAME=ems_user
DB_PASSWORD=change_me_strong_password
DB_USE_SSL=false
DB_POOL_SIZE=10

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# JWT - generate a strong random 256-bit+ secret for production
# e.g. openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-base64-secret-at-least-64-bytes
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_ISSUER=ems-backend

# CORS - comma separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# Unsplash API (used by frontend, listed here too for reference)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Seed/default admin account created on first boot
DEFAULT_ADMIN_EMAIL=admin@ems.local
DEFAULT_ADMIN_PASSWORD=ChangeThisAdminPassword!1

# Logging
LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG
ACTUATOR_HEALTH_DETAILS=never
